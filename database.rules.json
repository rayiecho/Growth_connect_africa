{
  "rules": {
    // ── Applicants ─────────────────────────────────────────────────────────
    // Write allowed only from the server (Admin SDK bypasses these checks).
    // Anonymous clients can read only their own application lookup via the
    // byEmail index, which itself reveals nothing more than yes/no membership.
    "applicants": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": [
        "dateApplied",
        "emailResponseStatus",
        "scheduledSendDate",
        "videoInviteWindow",
        "currentStatus",
        "currentStage",
        "lastUpdated"
      ]
    },

    "applicantsByEmail": {
      // Anonymous browser can probe whether an email has applied — required
      // by /apply and /video-pitch. The data returned is just a {applicantId}
      // pointer, not the applicant's payload.
      ".read": true,
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["applicantId"]
    },

    // ── Video submissions ──────────────────────────────────────────────────
    "videoSubmissions": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": [
        "reviewStatus",
        "submittedAt",
        "approvedAt",
        "rejectedAt",
        "inviteEmailSentAt",
        "applicantId"
      ]
    },
    "videoSubmissionsByApplicant": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["submittedAt"]
    },

    // ── Verifications ──────────────────────────────────────────────────────
    "verifications": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["reviewStatus", "submittedAt", "applicantId"]
    },
    "verificationsByApplicant": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    // ── Engine run logs (cron observability) ───────────────────────────────
    "engineRunLog": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["ranAt"]
    },

    // ── Default-deny everything else ───────────────────────────────────────
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
