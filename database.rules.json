{
  "rules": {
    "applicants": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": [
        "dateApplied",
        "emailResponseStatus",
        "scheduledSendDate",
        "videoInviteWindow",
        "videoInviteSentAt",
        "currentStatus",
        "currentStage",
        "lastUpdated"
      ]
    },
    "applicantsByEmail": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },

    "videoSubmissions": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": [
        "reviewStatus",
        "submittedAt",
        "approvedAt",
        "rejectedAt",
        "verificationInviteSentAt",
        "trainingEmailSentAt",
        "applicantId"
      ]
    },
    "videoSubmissionsByApplicant": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "verifications": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["reviewStatus", "submittedAt", "applicantId"]
    },
    "verificationsByApplicant": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "templates": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "verificationBatches": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["batchDate"]
    },

    "sendLog": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["applicantId", "templateKey", "sentAt"]
    },

    "engineRunLog": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      ".indexOn": ["ranAt"]
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
