# Copy this file to .env.local and fill in your own values.

# AWS SES — used by lib/engine/ses.ts for sending emails.
# Keep these server-side only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SES_FROM_EMAIL=hello@growthconnect.africa
SES_FROM_NAME=GrowthConnect Team

# Shared secret for protecting cron endpoints.
# Set this in Vercel Project Settings → Environment Variables as well.
# Generate with: openssl rand -base64 32
CRON_SECRET=
