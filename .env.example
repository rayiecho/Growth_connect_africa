# ── Firebase Web SDK (public — shipped to the browser) ──────────────────────
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Realtime Database URL — looks like https://YOUR_PROJECT-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin SDK (server-side only — NEVER expose to the browser) ──────
# Pick ONE of the two options below.
#
# Option A (recommended for Render): base64-encode your service account JSON.
#   macOS/Linux:  base64 -i secrets/firebase-service-account.json | tr -d '\n'
#   Windows:      certutil -encode secrets\firebase-service-account.json | findstr /v CERTIFICATE
# Paste the entire output as the value below (no line breaks).
FIREBASE_SERVICE_ACCOUNT_BASE64=
#
# Option B (local dev only): absolute path to your service account JSON file.
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/secrets/firebase-service-account.json

# ── AWS SES (existing — keeping for the email engine) ────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SES_FROM_EMAIL=hello@growthconnect.africa
SES_FROM_NAME=GrowthConnect Team

# ── Cron (existing pattern, now scheduled by Render Cron Jobs) ──────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=
# Same value, exposed because the admin dashboard calls video-action endpoints.
NEXT_PUBLIC_CRON_SECRET=

# ── Application ─────────────────────────────────────────────────────────────
# Public site URL (Render provides this once deployed)
NEXT_PUBLIC_SITE_URL=https://growthconnect.africa
