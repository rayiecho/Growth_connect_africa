# Copy this file to .env.local and fill in your own values.
# Get these from your Supabase project: Settings -> API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — used ONLY in server-side API routes.
# NEVER expose with NEXT_PUBLIC_ or use in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# AWS SES — used by lib/engine/ses.ts for sending emails.
# Keep these server-side only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SES_FROM_EMAIL=hello@growthconnect.africa
SES_FROM_NAME=GrowthConnect Team

# Shared secret for protecting cron endpoints.
# Set this in Vercel Project Settings → Environment Variables as well.
# Generate with: openssl rand -base64 32
CRON_SECRET=
